```python
@app.get("/api/{tenant_id}/insights")
def insights(tenant_id: str):
    db = get_db(f"tenant_{tenant_id}")
    cur = db.cursor(dictionary=True)
    
    # Últimas 50 tool calls — lo que pide el doc
    cur.execute("""
        SELECT tc.tool_name, tc.duration_ms, tc.success,
               a.type as agent_type
        FROM tool_calls tc
        JOIN sessions s ON tc.session_id = s.id
        JOIN agents a ON s.agent_id = a.id
        ORDER BY tc.called_at DESC LIMIT 50
    """)
    context = cur.fetchall()

    resp = requests.post(
        "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions",
        headers={"Authorization": f"Bearer {os.getenv('DASHSCOPE_API_KEY')}"},
        json={"model": "qwen-plus",
              "messages": [
                {"role": "system", "content": "You are an AI agent performance analyst. Respond ONLY with valid JSON: {\"bottlenecks\": [], \"recommendations\": [], \"efficiency_score\": 0}"},
                {"role": "user", "content": f"Analyze this agent activity and identify patterns: {context}"}
              ]}
    )
    return resp.json()["choices"][0]["message"]["content"]
