# provision.py
import mysql.connector, os
from dotenv import load_dotenv
load_dotenv()

def get_admin():
    return mysql.connector.connect(
        host=os.getenv("TIDB_HOST"),
        port=int(os.getenv("TIDB_PORT", 4000)),
        user=os.getenv("TIDB_USER"),
        password=os.getenv("TIDB_PASSWORD"),
        ssl_ca="/etc/ssl/certs/ca-certificates.crt"
    )

PREFIX = os.getenv("TIDB_CLUSTER_PREFIX")  # te lo dan en el evento

def provision_tenant(tenant_name: str):
    db = get_admin()
    cur = db.cursor()
    t = tenant_name

    statements = [
        f"CREATE DATABASE IF NOT EXISTS {t}",

        f"""CREATE TABLE IF NOT EXISTS {t}.agents (
            id BIGINT PRIMARY KEY AUTO_RANDOM,
            name VARCHAR(100),
            type ENUM('research','code_gen','data_analysis','web_interaction'),
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)""",

        f"""CREATE TABLE IF NOT EXISTS {t}.sessions (
            id BIGINT PRIMARY KEY AUTO_RANDOM,
            agent_id BIGINT,
            status ENUM('running','completed','failed'),
            started_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            ended_at TIMESTAMP NULL)""",

        f"""CREATE TABLE IF NOT EXISTS {t}.state_snapshots (
            id BIGINT PRIMARY KEY AUTO_RANDOM,
            session_id BIGINT,
            state_data JSON,
            captured_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)""",

        f"""CREATE TABLE IF NOT EXISTS {t}.tool_calls (
            id BIGINT PRIMARY KEY AUTO_RANDOM,
            session_id BIGINT,
            tool_name VARCHAR(100),
            duration_ms INT,
            success BOOLEAN,
            called_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)""",

        f"""CREATE TABLE IF NOT EXISTS {t}.insights (
            id BIGINT PRIMARY KEY AUTO_RANDOM,
            tenant_id VARCHAR(50),
            analysis JSON,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)""",

        # TiFlash — módulo 3
        f"ALTER TABLE {t}.sessions SET TIFLASH REPLICA 1",
        f"ALTER TABLE {t}.tool_calls SET TIFLASH REPLICA 1",
        f"ALTER TABLE {t}.agents SET TIFLASH REPLICA 1",

        # Views — Quick BI
        f"""CREATE OR REPLACE VIEW {t}.v_agent_performance AS
            SELECT a.type, COUNT(s.id) as total_sessions,
                   AVG(TIMESTAMPDIFF(SECOND, s.started_at, s.ended_at)) as avg_duration_sec,
                   SUM(CASE WHEN s.status='completed' THEN 1 ELSE 0 END) as completed
            FROM {t}.sessions s JOIN {t}.agents a ON s.agent_id = a.id
            GROUP BY a.type""",

        f"""CREATE OR REPLACE VIEW {t}.v_tool_usage AS
            SELECT tool_name, COUNT(*) as total_calls,
                   AVG(duration_ms) as avg_ms,
                   SUM(CASE WHEN success THEN 1 ELSE 0 END) as successes
            FROM {t}.tool_calls GROUP BY tool_name ORDER BY total_calls DESC""",

        f"""CREATE OR REPLACE VIEW {t}.v_daily_sessions AS
            SELECT DATE(started_at) as day, COUNT(*) as sessions,
                   SUM(CASE WHEN status='failed' THEN 1 ELSE 0 END) as failures
            FROM {t}.sessions GROUP BY day ORDER BY day""",

        # RBAC
        f"CREATE USER IF NOT EXISTS '{PREFIX}.user_{t}'@'%' IDENTIFIED BY 'Hackathon2026!'",
        f"GRANT SELECT, INSERT, UPDATE ON {t}.* TO '{PREFIX}.user_{t}'@'%'",

        # quickbi_reader solo sobre views
        f"CREATE USER IF NOT EXISTS '{PREFIX}.quickbi_reader'@'%' IDENTIFIED BY 'QuickBI2026!'",
        f"GRANT SELECT ON {t}.v_agent_performance TO '{PREFIX}.quickbi_reader'@'%'",
        f"GRANT SELECT ON {t}.v_tool_usage TO '{PREFIX}.quickbi_reader'@'%'",
        f"GRANT SELECT ON {t}.v_daily_sessions TO '{PREFIX}.quickbi_reader'@'%'",
    ]

    for sql in statements:
        try:
            cur.execute(sql)
            print(f"  ✅ {sql[:60]}...")
        except Exception as e:
            print(f"  ⚠️  {e}")

    db.commit()
    db.close()
    print(f"🚀 {tenant_name} listo\n")

if __name__ == "__main__":
    import sys
    tenants = sys.argv[1:] or [
        "tenant_alpha","tenant_beta","tenant_gamma","tenant_delta","tenant_epsilon"
    ]
    for t in tenants:
        provision_tenant(t)
