## Schema AgentNexus (reemplaza todo el SQL anterior)

```sql
CREATE DATABASE tenant_alpha;
USE tenant_alpha;

CREATE TABLE agents (
    id BIGINT PRIMARY KEY AUTO_RANDOM,
    name VARCHAR(100),
    type ENUM('research','code_gen','data_analysis','web_interaction'),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE sessions (
    id BIGINT PRIMARY KEY AUTO_RANDOM,
    agent_id BIGINT,
    status ENUM('running','completed','failed'),
    started_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ended_at TIMESTAMP NULL
);

CREATE TABLE state_snapshots (
    id BIGINT PRIMARY KEY AUTO_RANDOM,
    session_id BIGINT,
    state_data JSON,
    captured_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE tool_calls (
    id BIGINT PRIMARY KEY AUTO_RANDOM,
    session_id BIGINT,
    tool_name VARCHAR(100),
    duration_ms INT,
    success BOOLEAN,
    called_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- TiFlash obligatorio
ALTER TABLE tool_calls SET TIFLASH REPLICA 1;
ALTER TABLE sessions SET TIFLASH REPLICA 1;

-- Views para Quick BI
CREATE VIEW v_agent_performance AS
SELECT a.type, COUNT(s.id) as total_sessions,
       AVG(TIMESTAMPDIFF(SECOND, s.started_at, s.ended_at)) as avg_duration_sec,
       SUM(CASE WHEN s.status='completed' THEN 1 ELSE 0 END) as completed
FROM sessions s JOIN agents a ON s.agent_id = a.id
GROUP BY a.type;

CREATE VIEW v_tool_usage AS
SELECT tool_name, COUNT(*) as total_calls,
       AVG(duration_ms) as avg_ms,
       SUM(CASE WHEN success THEN 1 ELSE 0 END) as successes
FROM tool_calls GROUP BY tool_name ORDER BY total_calls DESC;

CREATE VIEW v_daily_sessions AS
SELECT DATE(started_at) as day, COUNT(*) as sessions,
       SUM(CASE WHEN status='failed' THEN 1 ELSE 0 END) as failures
FROM sessions GROUP BY day ORDER BY day;
```

